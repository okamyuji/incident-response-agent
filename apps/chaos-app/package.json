{
  "name": "chaos-app",
  "version": "1.0.0",
  "description": "TypeScript sample app that intentionally causes failures for Claude incident detection validation",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "build": "tsc && tsc-alias",
    "clean": "rm -rf dist coverage",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "check": "pnpm format:check && pnpm lint && pnpm test"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "printWidth": 100,
    "tabWidth": 2,
    "arrowParens": "always",
    "endOfLine": "lf"
  },
  "dependencies": {
    "express": "5.2.1",
    "pino": "10.3.1",
    "pino-http": "11.0.0"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "25.6.0",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.4",
    "prettier": "3.8.3",
    "supertest": "7.2.2",
    "tsc-alias": "1.8.16",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vite": "^8.0.8",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.4"
  }
}

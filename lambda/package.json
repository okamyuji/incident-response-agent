{
  "name": "@ira/lambdas",
  "version": "1.0.0",
  "description": "Bedrock-invoking Lambda functions (Haiku / Sonnet / Opus)",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "build": "tsup",
    "clean": "rm -rf dist coverage",
    "package": "pnpm build && node scripts/zip.mjs",
    "check": "pnpm format:check && pnpm lint && pnpm test"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "printWidth": 100,
    "tabWidth": 2,
    "arrowParens": "always",
    "endOfLine": "lf"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "3.1032.0",
    "@aws-sdk/client-cloudwatch-logs": "3.1032.0",
    "@aws-sdk/client-dynamodb": "3.1032.0",
    "@aws-sdk/client-sns": "3.1032.0",
    "@aws-sdk/lib-dynamodb": "3.1032.0",
    "ulid": "3.0.2"
  },
  "devDependencies": {
    "@types/aws-lambda": "8.10.161",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.4",
    "prettier": "3.8.3",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vite": "^8.0.0",
    "vitest": "4.1.4"
  }
}
